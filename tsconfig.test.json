{
    "compilerOptions": {
        "target": "ES2022",
        "module": "commonjs",
        "outDir": "./test-build",
        "rootDir": ".",
        "strict": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "moduleResolution": "node10",
        "ignoreDeprecations": "6.0",
        "sourceMap": true
    },
    "include": ["src/**/*.ts", "test/**/*.ts"],
    "exclude": ["node_modules"]
}
