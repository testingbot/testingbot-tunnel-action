{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "ignoreDeprecations": "6.0",
    "outDir": "./lib",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleResolution": "node10"
  },
  "exclude": ["node_modules", "**/*.test.ts"]
}
