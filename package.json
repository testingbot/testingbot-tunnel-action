{
  "name": "testingbot-tunnel-action",
  "version": "1.0.0",
  "description": "Set up the TestingBot Test Environment",
  "homepage": "https://github.com/testingbot/testingbot-tunnel-action#readme",
  "bugs": {
    "url": "https://github.com/testingbot/testingbot-tunnel-action/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/testingbot/testingbot-tunnel-action.git"
  },
  "scripts": {
    "format": "prettier --write '**/*.ts'",
    "format-check": "prettier --check '**/*.ts'",
    "lint": "eslint 'src/**/*.ts'",
    "build": "ncc build src/index.ts -o dist/main && ncc build src/post.ts -o dist/post",
    "pretest": "npm run build:test",
    "test": "mocha --grep @slow --invert",
    "pretest:slow": "npm run build:test",
    "test:slow": "mocha --grep @slow --timeout 75000",
    "build:test": "tsc -p tsconfig.test.json && cp src/options.json test-build/src/options.json",
    "test:e2e": "http-server ./test -p 8080 > /dev/null 2>&1 & node ./test/e2e.test.js",
    "all": "npm run build && npm run format && npm run lint && npm run test"
  },
  "author": "Jochen Delabie <jochen@testingbot.com>",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "keywords": [
    "testingbot",
    "tunnel",
    "proxy",
    "testingbot-tunnel"
  ],
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/sinon": "^21.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^8.57.1",
    "eslint-plugin-github": "^5.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "http-server": "^14.1.1",
    "mocha": "^11.7.5",
    "prettier": "^3.8.3",
    "sinon": "^21.0.3",
    "typescript": "^6.0.2",
    "webdriverio": "^9.27.0"
  },
  "overrides": {
    "diff": ">=8.0.3",
    "serialize-javascript": ">=7.0.3",
    "undici": ">=7.0.0"
  },
  "dependencies": {
    "@actions/artifact": "^6.2.1",
    "@actions/core": "^1.11.1",
    "@actions/exec": "^1.1.1"
  }
}
